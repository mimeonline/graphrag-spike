# openai oder github
LLM_PROVIDER=openai

# OpenAI-Direktzugang
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-5-nano

# GitHub Models: PAT mit models:read verwenden.
# Alternativ kann GITHUB_TOKEN oder LLM_API_KEY gesetzt werden.
GITHUB_MODELS_API_KEY=
GITHUB_EMBEDDING_MODEL=openai/text-embedding-3-small
GITHUB_ANSWER_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Provider-unabhängige Overrides.
# Wenn leer/nicht gesetzt, nutzt das Notebook provider-spezifische Defaults.
# EMBEDDING_MODEL=
# ANSWER_MODEL=
EMBEDDING_DIM=1536
ANSWER_TEMPERATURE=0.2

NEO4J_URI=neo4j+s://<deine-aura-db>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional: Szenariofragen überschreiben. Wenn leer/nicht gesetzt, nutzt jedes
# Notebook seine eingebaute Standardfrage.
# Optional: Fragelevel je Szenario wählen: leicht, mittel oder schwer.
KLIMA_KOMMUNALE_KLIMAANPASSUNG_QUESTION_LEVEL=leicht
BSI_IT_GRUNDSCHUTZ_QUESTION_LEVEL=leicht
SOZIALBERICHT_2024_QUESTION_LEVEL=leicht
# KLIMA_KOMMUNALE_KLIMAANPASSUNG_QUESTION=
# BSI_IT_GRUNDSCHUTZ_QUESTION=
# SOZIALBERICHT_2024_QUESTION=

TOP_K=8
HOP_PENALTY=0.08
