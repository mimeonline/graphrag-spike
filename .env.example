OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_ANSWER_MODEL=gpt-5-nano
OPENAI_ANSWER_TEMPERATURE=0.2

NEO4J_URI=neo4j+s://<deine-aura-db>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

